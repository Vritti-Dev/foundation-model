# Copy to .env and fill in real values for production.
# docker-compose.yml uses the defaults below; you can leave them for local dev.

DATABASE_URL=postgresql+psycopg://vritti:vritti@localhost:5432/vritti

# Generate a real secret: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me

# Set true when serving over HTTPS in production.
COOKIE_SECURE=false

# Where the course book is served (relative URL).
COURSE_URL=/intro.html
